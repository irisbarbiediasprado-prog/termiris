#!/data/data/com.termux/files/usr/bin/bash
set -euo pipefail

ROOT="$HOME/.termiris"
CACHE="$ROOT/cache/context"
CHANGED="$CACHE/changed-files.txt"
OUT="$CACHE/context.md"

mkdir -p "$CACHE"

{
    echo "# Termiris Context"
    echo
    echo "Gerado em: $(date)"
    echo

    if [ ! -s "$CHANGED" ]; then
        echo "(nenhuma alteração)"
        exit 0
    fi

    sort -u "$CHANGED" | while IFS= read -r FILE; do
        REL="${FILE#$ROOT/}"

        echo "## $REL"
        echo

        if git -C "$ROOT" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
            if git -C "$ROOT" ls-files --error-unmatch "$REL" >/dev/null 2>&1; then
                DIFF="$(git -C "$ROOT" diff -- "$REL")"
                if [ -n "$DIFF" ]; then
                    echo '```diff'
                    printf '%s\n' "$DIFF"
                    echo '```'
                else
                    echo "_Sem diff (arquivo salvo, mas sem mudanças em relação ao Git)._"
                fi
            else
                echo "_Arquivo não versionado._"
                echo
                echo '```'
                cat "$FILE"
                echo '```'
            fi
        fi

        echo
    done
} > "$OUT"

: > "$CHANGED"

echo "🟢 Contexto atualizado"
