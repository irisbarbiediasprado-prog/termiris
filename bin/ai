#!/data/data/com.termux/files/usr/bin/bash

CHAT=ia_chat
MAIN=main

if ! tmux has-session -t "$CHAT" 2>/dev/null; then
    tmux new-session -d -s "$CHAT" -n Chat 'aichat -s termiris_ctx'
    tmux new-window -t "$CHAT":2 -n Monitor \
        'find . -type f \( -name "*.c" -o -name "*.h" -o -name "*.py" -o -name "*.js" -o -name "*.lua" -o -name "*.vim" -o -name "*.sh" -o -name "*.md" \) | entr -p ~/.termiris/bin/update_context.sh /_'
fi

CURRENT="$(tmux display-message -p '#{session_name}')"

if [ "$CURRENT" = "$CHAT" ]; then
    tmux switch-client -t "$MAIN"
else
    tmux switch-client -t "$CHAT"
fi

tmux display-message "🤖 $(tmux display-message -p '#{session_name}')"
