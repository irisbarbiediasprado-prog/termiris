#!/data/data/com.termux/files/usr/bin/bash

CHAT=ia_chat
MAIN=main
WATCH_DIRS=(
    "$HOME/Projects"
    "$HOME/.termiris"
    "$HOME/.config"
)

start_monitor() {
    tmux new-window -d -t "$CHAT": -n Monitor "bash -c '
        echo \"🤖 Monitor iniciado\"

        inotifywait -m -r \
            -e modify,create,delete \
            --format \"%w%f\" \
            ${WATCH_DIRS[*]} 2>/dev/null |
        while read -r FILE; do
            case \"\$FILE\" in
                *.c|*.h|*.py|*.js|*.lua|*.vim|*.sh|*.md|*.yaml|*.yml|*.json|*.toml)
                    ~/.termiris/bin/update_context.sh \"\$FILE\"
                    ;;
            esac
        done
    '"
}

tmux has-session -t "$CHAT" 2>/dev/null || \
    tmux new-session -d -s "$CHAT" -n Chat 'exec aichat -s termiris_ctx'

tmux list-windows -t "$CHAT" | grep -q 'Monitor' || start_monitor

if ! pgrep -f 'inotifywait.*Projects' >/dev/null; then
    tmux kill-window -t "$CHAT":Monitor 2>/dev/null
    start_monitor
fi

CURRENT="$(tmux display-message -p '#{session_name}')"

if [ "$CURRENT" = "$CHAT" ]; then
    tmux switch-client -t "$MAIN"
else
    tmux switch-client -t "$CHAT"
fi

tmux display-message "🤖 $(tmux display-message -p '#{session_name}')"
