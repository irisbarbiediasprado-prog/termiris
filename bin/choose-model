#!/data/data/com.termux/files/usr/bin/bash
set -euo pipefail

CFG="$HOME/.config/aichat/config.yaml"

command -v aichat >/dev/null || { echo "❌ aichat não encontrado"; exit 1; }
command -v fzf >/dev/null || { echo "❌ fzf não encontrado"; exit 1; }
command -v yq >/dev/null || { echo "❌ yq não encontrado"; exit 1; }

models="$(aichat --list-models)"

provider="$(
printf '%s\n' "$models" \
| cut -d: -f1 \
| sort -u \
| uniq \
| fzf \
    --prompt='🤖 Provider > ' \
    --layout=reverse \
    --border \
    --height=80%
)" || exit 130

model="$(
printf '%s\n' "$models" \
| grep "^${provider}:" \
| fzf \
    --prompt="🧠 ${provider} > " \
    --layout=reverse \
    --border \
    --height=80%
)" || exit 130

MODEL="$model" yq -i '.model = strenv(MODEL)' "$CFG"

if [ "$(yq -r '.model' "$CFG")" = "$model" ]; then
    printf '✅ Modelo selecionado: %s\n' "$model"
else
    echo "❌ Falha ao atualizar $CFG"
    exit 1
fi
