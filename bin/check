#!/data/data/com.termux/files/usr/bin/bash

ok(){ printf "🟢 %s\n" "$1"; }
err(){ printf "🔴 %s\n" "$1"; }

echo "=== 🔍 Termiris Health Check ==="

echo
echo "Dependências"
for cmd in tmux fzf fd rg bat git entr aichat curl; do
    if command -v "$cmd" >/dev/null 2>&1; then
        ok "$cmd"
    else
        err "$cmd"
    fi
done

echo
echo "Arquivos"
for f in \
    ~/.termiris/init.sh \
    ~/.termiris/config/bashrc \
    ~/.termiris/config/tmux.conf \
    ~/.termiris/config/termux.properties \
    ~/.termiris/bin/ai \
    ~/.termiris/bin/update_context.sh \
    ~/.termiris/bin/check_ai_health.sh
do
    [ -f "$f" ] && ok "$f" || err "$f"
done

echo
echo "🤖 IA"
~/.termiris/bin/check_ai_health.sh

echo
echo "Extra Keys"
grep -q 'macro:"F1"' ~/.termux/termux.properties \
    && ok "Botão 🤖" \
    || err "Botão 🤖"

echo
echo "tmux"
tmux list-keys | grep -q 'run-shell.*\.termiris/bin/ai' \
    && ok "Toggle IA" \
    || err "Toggle IA"

